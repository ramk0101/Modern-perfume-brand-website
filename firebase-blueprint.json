{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "productName": { "type": "string" },
        "size": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePaid": { "type": "string" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "customerName": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["orderId", "userId", "productName", "pricePaid"]
    },
    "Formula": {
      "title": "Formula",
      "description": "Custom bespoke perfume formulas curated by users",
      "type": "object",
      "properties": {
        "formulaId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "vibe": { "type": "string" },
        "intensity": { "type": "string" },
        "topNotes": { "type": "string" },
        "heartNotes": { "type": "string" },
        "baseNotes": { "type": "string" },
        "matchScore": { "type": "string" }
      },
      "required": ["formulaId", "userId", "name"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user profile marker",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid"]
    },
    "Product": {
      "title": "Product",
      "description": "Fragrance product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "collection": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "detailedStory": { "type": "string" },
        "topNotes": { "type": "string" },
        "heartNotes": { "type": "string" },
        "baseNotes": { "type": "string" },
        "volume": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isOutOfStock": { "type": "boolean" },
        "stockCount": { "type": "number" }
      },
      "required": ["id", "name", "price"]
    },
    "StoreSetting": {
      "title": "Store Setting",
      "description": "Basic store configuration and shipping charges",
      "type": "object",
      "properties": {
        "settingId": { "type": "string" },
        "storeName": { "type": "string" },
        "storeDescription": { "type": "string" },
        "shippingCharges": { "type": "number" }
      },
      "required": ["settingId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase records logged in Firestore"
    },
    "formulas/{formulaId}": {
      "schema": "Formula",
      "description": "User custom formulations logged in Firestore"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Registered admins"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Fragrance products dynamic catalog"
    },
    "settings/{settingId}": {
      "schema": "StoreSetting",
      "description": "Global store settings"
    }
  }
}
