{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "productName": { "type": "string" },
        "size": { "type": "string" },
        "quantity": { "type": "number" },
        "pricePaid": { "type": "string" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "customerName": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["orderId", "userId", "productName", "pricePaid"]
    },
    "Formula": {
      "title": "Formula",
      "description": "Custom bespoke perfume formulas curated by users",
      "type": "object",
      "properties": {
        "formulaId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "vibe": { "type": "string" },
        "intensity": { "type": "string" },
        "topNotes": { "type": "string" },
        "heartNotes": { "type": "string" },
        "baseNotes": { "type": "string" },
        "matchScore": { "type": "string" }
      },
      "required": ["formulaId", "userId", "name"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase records logged in Firestore"
    },
    "formulas/{formulaId}": {
      "schema": "Formula",
      "description": "User custom formulations logged in Firestore"
    }
  }
}
